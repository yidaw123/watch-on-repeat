{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": "off",
    "no-undef": "off",
    "no-empty": "off",
    "no-constant-condition": "off",
    "no-useless-escape": "off",
    "no-redeclare": "error",
    "no-dupe-keys": "error",
    "no-dupe-args": "error",
    "no-extra-semi": "off",
    "no-mixed-spaces-and-tabs": "off"
  }
}
